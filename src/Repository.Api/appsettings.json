{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=MyAppDb;Trusted_Connection=True;"
    },
    "SortableProperties": {
        // usa il nome semplice della classe (es. "Product") oppure il FullTypeName se preferisci
        "Product": [ "Id", "Name", "Price" ]

        // Esempio per altre entità:
        // "OtherEntity": [ "Id", "Title", "CreatedAt" ]
    }
}